from transformers import AutoTokenizer, AutoModelForCausalLM, pipeline
import torch

# Path to your local model directory
model_path = r"C:\devhome\projects\meta-llama-Llama-3-2-8B-Instruct"

# Load tokenizer and model
tokenizer = AutoTokenizer.from_pretrained(model_path, trust_remote_code=True)
model = AutoModelForCausalLM.from_pretrained(model_path, device_map="auto", torch_dtype=torch.float16, trust_remote_code=True)

# Create pipeline
llm_pipeline = pipeline("text-generation", model=model, tokenizer=tokenizer)

# Prompt
prompt = "Explain the importance of caching in web applications."

# Run generation
outputs = llm_pipeline(prompt, max_new_tokens=200, do_sample=True, temperature=0.7)

# Print result
print("Response:\n", outputs[0]["generated_text"])
